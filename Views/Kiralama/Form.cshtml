@model AliMertTosunAracSinavi.Models.Kiralama

@{
    ViewData["Title"] = "Araç Kiralama Formu";
}

<h2>Araç Kiralama Formu</h2>

<form asp-action="Form" method="post" enctype="multipart/form-data">
    <div>
        <label>Araç Adı:</label>
        <input asp-for="AracAdi" required />
    </div>
    <div>
        <label>Başlangıç Tarihi:</label>
        <input asp-for="BaslangicTarihi" type="date" required />
    </div>
    <div>
        <label>Bitiş Tarihi:</label>
        <input asp-for="BitisTarihi" type="date" required />
    </div>
    <div>
        <label>Fotoğraf:</label>
        <input asp-for="FotoPath" type="file" required />
    </div>
    <button type="submit">Talebi Gönder</button>
</form>

@if (TempData["Success"] != null)
{
    <p style="color:green">@TempData["Success"]</p>
}